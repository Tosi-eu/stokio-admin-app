# Cliente admin (Vite / Electron) — expõe apenas variáveis prefixadas com VITE_
VITE_API_BASE=http://localhost/api/v1
VITE_X_API_KEY=

# API de preços (stokio-api-price-search) — configurar no env do serviço ou no Compose.
# O nível de log dessa API define-se só no .env do próprio serviço (LOG_LEVEL).
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=40

GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300

BACKEND_INTERNAL_URL=
